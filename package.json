{
  "name": "docgen-mcp-server",
  "version": "6.1.0",
  "description": "Servidor MCP (stdio) para leitura, escrita, renderização e edição de documentos e planilhas.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "docgen-mcp-server": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build",
    "release": "node scripts/bump-version.mjs && npm publish --access=public",
    "release:minor": "node scripts/bump-version.mjs minor && npm publish --access=public",
    "release:major": "node scripts/bump-version.mjs major && npm publish --access=public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "docx",
    "pdf",
    "excel",
    "cursor",
    "claude"
  ],
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "diff": "^7.0.0",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^4.5.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^23.11.1",
    "turndown": "^7.2.0",
    "xlsx": "^0.18.5",
    "yauzl": "^2.10.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^6.0.3",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.13.14",
    "@types/pdf-parse": "^1.1.4",
    "@types/turndown": "^5.0.5",
    "@types/yauzl": "^2.10.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
